{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/api/auth", "destination": "/api/auth" },
    { "source": "/api/gemini", "destination": "/api/gemini" },
    { "source": "/api/image", "destination": "/api/image" },
    { "source": "/api/quiz", "destination": "/api/quiz" },
    { "source": "/api/siliconflow", "destination": "/api/siliconflow" },
    { "source": "/api/tts", "destination": "/api/tts" },
    { "source": "/api/video-search", "destination": "/api/video-search" },
    { "source": "/api/health", "destination": "/api/health" },
    { "source": "/api/cron-health", "destination": "/api/cron-health" },
    { "source": "/api/feedback", "destination": "/api/feedback" },
    { "source": "/api/error-report", "destination": "/api/error-report" }
  ],
  "functions": {
    "api/image.js": {
      "maxDuration": 60
    },
    "api/gemini.js": {
      "maxDuration": 60
    },
    "api/quiz.js": {
      "maxDuration": 30
    },
    "api/tts.js": {
      "maxDuration": 25
    },
    "api/video-search.js": {
      "maxDuration": 15
    },
    "api/health.js": {
      "maxDuration": 15
    },
    "api/cron-health.js": {
      "maxDuration": 20
    },
    "api/feedback.js": {
      "maxDuration": 10
    },
    "api/error-report.js": {
      "maxDuration": 10
    }
  },
  "crons": [
    {
      "path": "/api/cron-health",
      "schedule": "0 0 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" },
        { "key": "Permissions-Policy", "value": "geolocation=(), microphone=(), camera=(), payment=()" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://esm.sh https://browser.sentry-cdn.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https: wss:; media-src 'self' blob: https:; worker-src 'self' blob:; frame-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'" }
      ]
    }
  ]
}
