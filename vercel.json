{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/api/auth", "destination": "/api/auth" },
    { "source": "/api/gemini", "destination": "/api/gemini" },
    { "source": "/api/image", "destination": "/api/image" },
    { "source": "/api/quiz", "destination": "/api/quiz" },
    { "source": "/api/siliconflow", "destination": "/api/siliconflow" },
    { "source": "/api/tts", "destination": "/api/tts" },
    { "source": "/api/video-search", "destination": "/api/video-search" }
  ],
  "functions": {
    "api/image.js": {
      "maxDuration": 60
    },
    "api/quiz.js": {
      "maxDuration": 30
    },
    "api/tts.js": {
      "maxDuration": 25
    },
    "api/video-search.js": {
      "maxDuration": 15
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
